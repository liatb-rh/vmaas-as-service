{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "strict": true,
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@vmaas-as-service/ui-kit": ["../../libs/ui-kit/src/index.ts"],
      "@vmaas-as-service/ui-kit/*": ["../../libs/ui-kit/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "webpack.config.ts", "typings.d.ts"]
}
